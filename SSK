local function getClosestEnemy(hrp)
	local enemyService = workspace:FindFirstChild("EnemyService")
	if not enemyService then return nil end

	local closestHRP = nil
	local closestDist = math.huge

	for _, enemy in ipairs(enemyService:GetChildren()) do
		for _, child in ipairs(enemy:GetDescendants()) do
			if child.Name == "HumanoidRootPart" and child:IsA("BasePart") then
				local dist = (hrp.Position - child.Position).Magnitude
				if dist < closestDist then
					closestDist = dist
					closestHRP = child
				end
				break
			end
		end
	end

	return closestHRP
end

local CHarONAnimationID = "100547102250054"

local function hookCharon(boss)

	if not string.find(boss.Name,"Charon") then
		return
	end

	local humanoid = boss:WaitForChild("Humanoid",5)
	if not humanoid then return end

	local animator = humanoid:WaitForChild("Animator",5)
	if not animator then return end

	print("Hook Charon:",boss.Name)


	animator.AnimationPlayed:Connect(function(track)

    local id = track.Animation.AnimationId
    id = string.gsub(id,"rbxassetid://","")


    if id == CHarONAnimationID then

        print("🔥 CHARON WIND START")

        CharonSkillActive = true

        -- รอ 1.5 วิ แล้วดันระยะออกไป 200
        task.delay(0.5,function()

            if CharonSkillActive then
                print("⚠️ DISTANCE 200")
                BEHIND_DISTANCE = DANGER_DISTANCE
            end

        end)

        -- รออีก 4 วิ หลังจากนั้น แล้วกลับค่าเดิม (รวม 5.5 วิจากเริ่มท่า)
        task.delay(0.5 + 1.5,function()

            print("✅ CHARON WIND END")

            CharonSkillActive = false
            BEHIND_DISTANCE = NORMAL_DISTANCE

        end)

    end

end)

end



